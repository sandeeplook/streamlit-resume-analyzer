# Copy this file to .streamlit/secrets.toml for local runs.
# On Streamlit Community Cloud, paste these same keys/values into
# your app's Settings → Secrets instead of committing a secrets.toml file.

ANTHROPIC_API_KEY = "your_anthropic_api_key_here"
ANTHROPIC_MODEL = "claude-sonnet-4-6"
ANTHROPIC_MAX_TOKENS = "4096"
MAX_UPLOAD_SIZE_MB = "10"
